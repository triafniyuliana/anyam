// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// USER
enum Role {
  admin
  pengguna
  pengrajin
}

enum AuthProvider {
  local
  google
}

model User {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String        @unique
  password      String?
  photo         String?
  role          Role          @default(pengguna)
  googleId      String?
  otpCode       String?
  otpExpired    DateTime?
  authProvider  AuthProvider  @default(local)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  pengrajinProfile  PengrajinProfile?

  reviews           Review[] @relation("UserReview")

  pengrajinReviews  Review[] @relation("PengrajinReview")

  bookingUser PelatihanBooking[] @relation("UserBooking")

  bookingPengrajin PelatihanBooking[] @relation("PengrajinBooking")

  pesanan           Pesanan[]

  keranjang         Keranjang[]

  notifikasi        Notifikasi[]

  aktivitas         Aktivitas[]
}

//VIDEO
model TutorialVideo {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  videoUrl   String
  thumbnail  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PengrajinProfile {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId

  userId        String    @unique @db.ObjectId

  alamat        String
  noTelpon      String

  pengalaman    String

  deskripsi     String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User @relation(fields: [userId], references: [id])
}

//REVIEW 
model Review {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId

  userId       String    @db.ObjectId

  pengrajinId  String    @db.ObjectId

  rating       Int

  ulasan       String

  createdAt    DateTime  @default(now())

  user         User @relation("UserReview", fields: [userId], references: [id])

  pengrajin    User @relation("PengrajinReview", fields: [pengrajinId], references: [id])
}

//KELAS PELATIHAN
model KelasPelatihan {

  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  namaKelas   String

  deskripsi   String

  harga       Int

  durasi      String

  lokasi      String   @default("Balai Desa Dukuhsembung")

  thumbnail   String?

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  bookings PelatihanBooking[]
}

//BOOKING PELATIHAN
model PelatihanBooking {

  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  orderId        String @unique 

  userId         String   @db.ObjectId

  pengrajinId    String   @db.ObjectId

  kelasId        String   @db.ObjectId

  namaLengkap    String

  noTelpon       String

  tanggal        String

  jamPelatihan     String

  jadwalPelatihan  DateTime

  lokasi         String   @default("Balai Desa Dukuhsembung")

  statusKelas    String   @default("menunggu")

  sudahReview Boolean @default(false)

  sertifikatUrl  String?

  totalBayar     Int

  metodeBayar    String

  statusBayar    String   @default("pending")

  buktiBayar     String?

  createdAt      DateTime @default(now())

  updatedAt      DateTime @updatedAt

  // RELATION
  user           User @relation("UserBooking", fields: [userId], references: [id])

  pengrajin      User @relation("PengrajinBooking", fields: [pengrajinId], references: [id])

  kelas          KelasPelatihan @relation(fields: [kelasId], references: [id])
}

//PRODUK
model Produk {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  namaProduk  String
  deskripsi   String
  harga       Int
  stok        Int

  foto        String?

  kategori    String

  ukuran      String?
  bahan       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  detailPesanan DetailPesanan[]

  keranjang Keranjang[]
}

//PESANAN
model Pesanan {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  userId          String   @db.ObjectId

  orderId         String   @unique

  namaPenerima    String
  noTelpon        String
  alamat          String

  totalBayar      Int

  metodeBayar     String

  statusBayar     String   @default("menunggu")

  statusPesanan   String   @default("diproses")

  nomorResi       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id])

  detailPesanan   DetailPesanan[]
}

//DETAIL PESANAN
model DetailPesanan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  pesananId   String   @db.ObjectId
  produkId    String   @db.ObjectId

  qty         Int

  harga       Int

  subtotal    Int

  pesanan     Pesanan @relation(fields: [pesananId], references: [id])

  produk      Produk  @relation(fields: [produkId], references: [id])
}

//KERANJANG
model Keranjang {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  userId      String   @db.ObjectId
  produkId    String   @db.ObjectId

  qty         Int      @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  produk      Produk   @relation(fields: [produkId], references: [id])
}

//NOTIFIKASI
model Notifikasi {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  userId      String   @db.ObjectId

  judul       String
  pesan       String

  dibaca      Boolean  @default(false)

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

//LOG AKTIVITAS
model Aktivitas {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  userId      String   @db.ObjectId

  judul       String

  deskripsi   String

  tanggal     String

  jam         String

  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id])
}


